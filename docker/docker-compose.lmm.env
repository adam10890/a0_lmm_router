# docker-compose.lmm.env — a0_lmm_router fleet configuration
# Located inside the plugin: usr/plugins/a0_lmm_router/docker/
# Can be edited manually or via lmm_host_helper.py API.
LLAMA_MODELS_DIR=C:/Users/frant/A0-Data-Permanent/A0_v.adam/models
CHAT_MODEL_PATH=/models/utility/gemma-4-e4b-uncensored/gemma-4-E4B-it-uncensored-Q4_K_M.gguf
CHAT_CTX_SIZE=65536
CHAT_PARALLEL=1
CHAT_BATCH_SIZE=512
CHAT_FLASH_ATTN=on
UTILITY_MODEL_PATH=/models/utility/qwen3.5_9b/Qwen3.5-9B-Q4_K_M.gguf
UTILITY_CTX_SIZE=16384
UTILITY_PARALLEL=1
UTILITY_BATCH_SIZE=512
UTILITY_FLASH_ATTN=on
EMBED_MODEL_PATH=/models/embedding/nomic/nomic-embed-text-v1.5.Q4_K_M.gguf
EMBED_CTX_SIZE=8192
EMBED_BATCH_SIZE=512

# ============================================================
# MTP (Multi-Token Prediction) per PR #22673
# Reference: https://github.com/ggml-org/llama.cpp/pull/22673
# (merged 2026-05-16, commit 10829dbc)
# ============================================================
# Canonical values:
#   UTILITY_SPEC_TYPE=draft-mtp     # exact flag value from the PR
#   UTILITY_SPEC_DRAFT_N_MAX=2      # PR recommends 2-3; 2 is the sweet spot
#
# Supported models (per PR): Qwen3.6-27B, Qwen3.6-35BA3B-MoE, DeepSeek V3/R1.
# NOT supported: Qwen3.5, Gemma, Mistral, Phi.
#
# NOTE (2026-05-21): the published ghcr.io/ggml-org/llama.cpp:server-cuda
# image checked locally accepts only:
#   none | ngram-cache | ngram-simple | ngram-map-k | ngram-map-k4v | ngram-mod
# i.e. PR #22673 is not yet in the published image. Setting draft-mtp here
# WILL crash the slot until the ghcr image is rebuilt or a local image is
# built from llama.cpp master (post-10829dbc).
#
# Activation path:
#   1. Set UTILITY_MODEL_PATH to an MTP-capable GGUF (Qwen3.6 / DeepSeek)
#   2. Use docker-compose.lmm.mtp.yml as an override (or start_with_mtp.bat)
#   3. Or uncomment the two lines below and restart the fleet
#
# UTILITY_SPEC_TYPE=draft-mtp
# UTILITY_SPEC_DRAFT_N_MAX=2

# ============================================================
# Optional optimization flags (opt-in)
# ============================================================
# Uncomment any line to activate the flag for that slot.
# Leave commented or empty = flag NOT passed to llama.cpp.
#
# --no-mmap: pin full model in RAM (faster init, needs enough RAM)
# --mlock:   lock model memory, prevent OS swap (needs memlock:-1 in compose)
# --n-cpu-moe N: offload N MoE experts to CPU (for models > VRAM)
# --cache-type-k / --cache-type-v: KV cache quantization
#   Values: f16 (default), q8_0, q5_0, q4_0 (smallest)
#
# CHAT (port 8080):
# CHAT_NO_MMAP=1
# CHAT_MLOCK=1
# CHAT_CPU_MOE=
# CHAT_CACHE_TYPE_K=q8_0
# CHAT_CACHE_TYPE_V=q8_0
# CHAT_GPU_LAYERS=999
#
# UTILITY (port 8088):
# UTILITY_NO_MMAP=1
# UTILITY_MLOCK=1
# UTILITY_CPU_MOE=
# UTILITY_CACHE_TYPE_K=q8_0
# UTILITY_CACHE_TYPE_V=q8_0
# UTILITY_GPU_LAYERS=999
#
# EMBEDDING (port 8082):
# EMBED_NO_MMAP=1
# EMBED_MLOCK=1
# EMBED_CACHE_TYPE_K=q4_0
# EMBED_CACHE_TYPE_V=q4_0
# EMBED_GPU_LAYERS=999
#
# ============================================================
# ROUTER MODE (a0-llama-router service)
# Uncomment the a0-llama-router service in docker-compose.lmm.yml,
# then set these variables. Comment out the 3 fixed-model services.
# ============================================================
# ROUTER_MODELS_DIR=/models
# ROUTER_MODELS_PRESET=/models/preset.ini
# ROUTER_MODELS_MAX=2    # ≥2 recommended — utility_model runs during chat turns in agent-zero
# ROUTER_CTX_SIZE=65536
# ROUTER_GPU_LAYERS=999
ROUTER_PARALLEL=1
# ROUTER_BATCH_SIZE=512
# ROUTER_FLASH_ATTN=on

# VISION (port 8084) — uncomment service in compose + set paths:
# VISION_MODEL_PATH=/models/vision/.../model.gguf
# VISION_MMPROJ_PATH=/models/vision/.../mmproj.gguf
# VISION_CTX_SIZE=32768
# VISION_GPU_LAYERS=999
#
# REASONING (port 8086) — uncomment service in compose + set path:
# REASONING_MODEL_PATH=/models/reasoning/.../model.gguf
# REASONING_CTX_SIZE=32768
# REASONING_GPU_LAYERS=999

# ============================================================
# Speculative Decoding / MTP (Multi-Token Prediction)
# Reference: https://github.com/ggml-org/llama.cpp/pull/22673
# (merged 2026-05-16, commit 10829dbc)
# ============================================================
# MTP uses prediction heads baked into the model weights — NO separate
# draft model needed, NO extra VRAM, NO extra download. The model predicts
# 2-3 tokens ahead using its built-in MTP heads; the main sampling pass
# verifies them; accepted tokens are free.
#
# Speedup from PR #22673 benchmark: ~1.85x decode (RTX 3090: 22.97 →
# 42.45 tok/s with ~70-75% draft acceptance). NOTE: prompt processing
# slows down slightly due to device-to-host embedding transfers.
#
# REQUIRES a model with embedded MTP weights:
#   ✅ Qwen3.6-27B            (canonical in PR #22673)
#   ✅ Qwen3.6-35BA3B (MoE)   (canonical in PR #22673)
#   ✅ DeepSeek V3 / R1
#   ❌ Qwen3.5 — NOT MTP-capable
#   ❌ Gemma / Mistral / Phi / LFM / SuperGemma
#
# Enabling draft-mtp on a non-MTP model is safe: llama-server will log a
# warning and fall back to no speculative decoding. Output is unaffected.
#
# _SPEC_TYPE values supported by PR #22673:
#   draft-mtp  | draft-simple | draft-eagle3
#   ngram-simple | ngram-mod | ngram-map-k
# ngram-* variants work on ANY model (no MTP heads needed). They are the
# only options if the published llama.cpp image doesn't yet include
# PR #22673 (check with: docker exec a0-llama-chat /app/llama-server --help
# | grep spec-type).
#
# To activate: uncomment and edit. Then restart with:
#   docker compose -f docker-compose.lmm.yml --env-file docker-compose.lmm.env down
#   docker compose -f docker-compose.lmm.yml --env-file docker-compose.lmm.env up -d
#
# CHAT slot (port 8080):
# CHAT_SPEC_TYPE=draft-mtp
# CHAT_SPEC_DRAFT_N_MAX=2
#
# UTILITY slot (port 8088):
# UTILITY_SPEC_TYPE=draft-mtp
# UTILITY_SPEC_DRAFT_N_MAX=2
#
# REASONING slot (port 8086) — also a good MTP candidate:
# REASONING_SPEC_TYPE=draft-mtp
# REASONING_SPEC_DRAFT_N_MAX=2
#
# Verify MTP is active after restart:
#   docker logs a0-llama-chat 2>&1 | grep -i "spec\|draft\|mtp"
